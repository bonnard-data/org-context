#!/bin/bash
# oc — Org Context CLI
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="${CLAUDE_PLUGIN_ROOT:-$(cd "$SCRIPT_DIR/.." && pwd)}"

resolve_email() {
  local email=$(python3 -c "import json; print(json.load(open('$HOME/.claude.json'))['oauthAccount']['emailAddress'])" 2>/dev/null)
  echo "${email:-unknown}"
}

resolve_role() {
  local email=$(resolve_email)
  local config="$PLUGIN_ROOT/plugin.yaml"
  local role=$(grep "^  ${email}:" "$config" 2>/dev/null | awk '{print $2}')
  if [ -z "$role" ]; then
    role=$(grep "^default_role:" "$config" | awk '{print $2}')
  fi
  echo "${role:-engineer}"
}

case "${1:-help}" in
  whoami)
    email=$(resolve_email)
    role=$(resolve_role)
    echo "Email: $email"
    echo "Role:  $role"
    ;;
  status)
    echo "Org Context v0.1.0"
    echo "Root:     $PLUGIN_ROOT"
    skill_count=$(find "$PLUGIN_ROOT/skills" -name "SKILL.md" 2>/dev/null | wc -l | tr -d ' ')
    cmd_count=$(find "$PLUGIN_ROOT/commands" -name "*.md" 2>/dev/null | wc -l | tr -d ' ')
    echo "Skills:   $skill_count"
    echo "Commands: $cmd_count"
    ;;
  sync)
    API_URL="${ORG_CONTEXT_API:-http://localhost:3000/api}"
    TOKEN="$CLAUDE_PLUGIN_OPTION_SYNCTOKEN"
    if [ -z "$TOKEN" ]; then
      echo "No sync token configured."
      exit 1
    fi
    response=$(curl -sf -H "Authorization: Bearer $TOKEN" "${API_URL}/sync" 2>/dev/null)
    if [ -n "$response" ]; then
      skill_count=$(echo "$response" | python3 -c "import sys,json; print(len(json.load(sys.stdin)['skills']))" 2>/dev/null)
      teams=$(echo "$response" | python3 -c "import sys,json; print(', '.join(json.load(sys.stdin)['teams']))" 2>/dev/null)
      find "$PLUGIN_ROOT/skills" -mindepth 1 -maxdepth 1 -type d -exec rm -rf {} + 2>/dev/null
      export PLUGIN_ROOT
      echo "$response" | python3 -c "
import sys, json, os
data = json.load(sys.stdin)
root = os.environ['PLUGIN_ROOT']
for skill in data['skills']:
    d = os.path.join(root, 'skills', skill['name'])
    os.makedirs(d, exist_ok=True)
    with open(os.path.join(d, 'SKILL.md'), 'w') as f:
        f.write(skill['content'])
" 2>/dev/null
      echo "Synced (teams: $teams). $skill_count skills."
    else
      echo "API unavailable."
    fi
    ;;
  validate)
    errors=0
    test -f "$PLUGIN_ROOT/.claude-plugin/plugin.json" && echo "  [OK] plugin.json" || { echo "  [FAIL] plugin.json missing"; errors=$((errors+1)); }
    test -f "$PLUGIN_ROOT/hooks/hooks.json" && echo "  [OK] hooks.json" || { echo "  [FAIL] hooks.json missing"; errors=$((errors+1)); }
    test -x "$PLUGIN_ROOT/bin/oc" && echo "  [OK] bin/oc executable" || { echo "  [FAIL] bin/oc not executable"; errors=$((errors+1)); }
    echo "Validation: $errors error(s)"
    exit $errors
    ;;
  help|*)
    echo "oc — Org Context CLI"
    echo ""
    echo "Commands:"
    echo "  whoami     Show current user and role"
    echo "  status     Show plugin status"
    echo "  sync       Force re-sync content"
    echo "  validate   Run installation checks"
    echo "  help       Show this help"
    ;;
esac
