#!/usr/bin/env node
// Status line script — shows alert count from Org Context platform
import { readFileSync } from 'node:fs'
import { homedir } from 'node:os'
import { join } from 'node:path'

const API_URL = process.env.ORG_CONTEXT_API || 'http://localhost:3000/api'
const SYNC_TOKEN = process.env.CLAUDE_PLUGIN_OPTION_SYNCTOKEN || ''

// Read stdin (status line input from Claude Code)
let input = ''
for await (const chunk of process.stdin) input += chunk
const data = JSON.parse(input)

const model = data?.model?.display_name || ''
const dir = data?.workspace?.current_dir?.split('/').pop() || ''

let alertBadge = ''
if (SYNC_TOKEN) {
  try {
    const res = await fetch(`${API_URL}/alerts/count`, {
      headers: { 'Authorization': `Bearer ${SYNC_TOKEN}` },
      signal: AbortSignal.timeout(2000),
    })
    if (res.ok) {
      const { count } = await res.json()
      if (count > 0) alertBadge = ` \x1b[33m🔔 ${count} alert${count > 1 ? 's' : ''}\x1b[0m`
    }
  } catch {}
}

process.stdout.write(`\x1b[2m${dir} | ${model}\x1b[0m${alertBadge}`)
