#!/usr/bin/env node

const { readFileSync, mkdirSync, writeFileSync, readdirSync, rmSync } = require('node:fs')
const { join, dirname } = require('node:path')
const { homedir } = require('node:os')

function loadApiKey() {
  if (process.env.CLAUDE_PLUGIN_OPTION_APIKEY) return process.env.CLAUDE_PLUGIN_OPTION_APIKEY
  try {
    const settings = JSON.parse(readFileSync(join(homedir(), '.claude', 'settings.json'), 'utf8'))
    return settings.pluginConfigs?.['org-context@bonnard-org-context']?.options?.apiKey || ''
  } catch { return '' }
}

const API_KEY = loadApiKey()
const API_URL = process.env.ORG_CONTEXT_API || 'https://api-production-746a.up.railway.app/api'
const JSON_OUTPUT = process.argv.includes('--json')

// ANSI colors
const dim = (s) => `\x1b[2m${s}\x1b[0m`
const bold = (s) => `\x1b[1m${s}\x1b[0m`
const green = (s) => `\x1b[32m${s}\x1b[0m`
const red = (s) => `\x1b[31m${s}\x1b[0m`
const yellow = (s) => `\x1b[33m${s}\x1b[0m`

function die(msg) {
  console.error(red(`Error: ${msg}`))
  process.exit(1)
}

function parseFlags(args) {
  const flags = {}
  const positional = []
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--json') continue
    if (args[i].startsWith('--')) {
      const key = args[i].slice(2)
      flags[key] = args[i + 1] || true
      i++
    } else {
      positional.push(args[i])
    }
  }
  return { flags, positional }
}

async function api(method, path, body) {
  if (!API_KEY) die('No API key. Configure your API key in the plugin settings.')
  const opts = {
    method,
    headers: { 'x-api-key': API_KEY, 'Content-Type': 'application/json' },
    signal: AbortSignal.timeout(10000),
  }
  if (body) opts.body = JSON.stringify(body)
  const res = await fetch(`${API_URL}${path}`, opts)
  if (!res.ok) {
    const err = await res.json().catch(() => ({}))
    die(`${res.status} — ${err.error || err.message || 'Request failed'}`)
  }
  return res.json()
}

function out(data) {
  if (JSON_OUTPUT) return console.log(JSON.stringify(data, null, 2))
  return data
}

function timeAgo(dateStr) {
  if (!dateStr) return '—'
  const diff = Date.now() - new Date(dateStr).getTime()
  const h = Math.floor(diff / 3600000)
  if (h < 1) return 'just now'
  if (h < 24) return `${h}h ago`
  const d = Math.floor(h / 24)
  if (d < 7) return `${d}d ago`
  return `${Math.floor(d / 7)}w ago`
}

function readContent(flags) {
  if (flags.file) return readFileSync(flags.file, 'utf8')
  if (flags.content) return flags.content
  return null
}

function parseTags(flags) {
  return flags.tags ? flags.tags.split(',').map(t => t.trim()) : undefined
}

async function parseTeamIds(flags) {
  if (!flags.teams) return undefined
  const names = flags.teams.split(',').map(t => t.trim())
  const ids = []
  for (const name of names) {
    ids.push(await resolveTeamId(name))
  }
  return ids
}

// --- Commands ---

const commands = {}

// whoami
commands.whoami = async () => {
  const data = await api('GET', '/me')
  if (JSON_OUTPUT) return out(data)
  console.log(`${bold('Email:')}  ${data.user.email}`)
  console.log(`${bold('Name:')}   ${data.user.name || dim('—')}`)
  console.log(`${bold('ID:')}     ${dim(data.user.id)}`)
}

// sync — full file-writing sync (same as SessionStart hook)
commands.sync = async () => {
  const data = await api('GET', '/sync')

  const PLUGIN_ROOT = join(dirname(__filename), '..')
  const HOME = process.env.HOME || homedir()
  const projectDir = process.env.CLAUDE_PROJECT_DIR

  function safeName(name) {
    return name.replace(/[^a-zA-Z0-9_-]/g, '_').slice(0, 100)
  }

  // Write skills
  const skillsDir = join(PLUGIN_ROOT, 'skills')
  mkdirSync(skillsDir, { recursive: true })
  try {
    for (const d of readdirSync(skillsDir, { withFileTypes: true })) {
      if (d.isDirectory()) rmSync(join(skillsDir, d.name), { recursive: true, force: true })
    }
  } catch {}
  for (const skill of data.skills || []) {
    const name = safeName(skill.name)
    const dir = join(skillsDir, name)
    mkdirSync(dir, { recursive: true })
    writeFileSync(join(dir, 'SKILL.md'), skill.content)
  }

  // Write rules
  const rulesDir = projectDir
    ? join(projectDir, '.claude', 'rules')
    : join(HOME, '.claude', 'rules')
  mkdirSync(rulesDir, { recursive: true })
  try {
    for (const f of readdirSync(rulesDir)) {
      if (f.startsWith('oc-') && f.endsWith('.md')) rmSync(join(rulesDir, f), { force: true })
    }
  } catch {}
  for (const rule of data.rules || []) {
    writeFileSync(join(rulesDir, `oc-${safeName(rule.name)}.md`), rule.content)
  }

  // Write agent guide
  const skillNames = (data.skills || []).map(s => s.name)
  writeFileSync(join(rulesDir, 'oc-agent-guide.md'), `# Org Context

You have the Org Context plugin installed. It provides your organization's knowledge, standards, and tools.

## What you have

- **Skills** (slash commands): ${skillNames.length ? skillNames.map(n => '/' + safeName(n)).join(', ') : 'none synced'}
- **Rules** (always-on context): ${(data.rules || []).length} org rules loaded — follow them
- **MCP tools**: Use \`search_docs\` to search company documentation, \`list_docs\` to browse available docs
- **CLI** (\`oc\`): Admin tool for managing org content

## CLI reference

\`\`\`
oc whoami                              # Current user info
oc sync                                # Re-sync content from server

oc skill list|get|create|update|delete # Manage skills
oc rule  list|get|create|update|delete # Manage rules
oc doc   list|get|create|update|delete|search # Manage docs

oc skill template / oc rule template / oc doc template  # Show example content

oc teams   list|get|create|delete|add-member|rm-member
oc members list|invite|set-role|remove
\`\`\`

Flags: \`--json\` for machine-readable output, \`--file <path>\` for content, \`--tags a,b\`, \`--org-wide\`, \`--description "..."\`

## Content types

**Skills** — On-demand procedures invoked via slash command. Write as step-by-step instructions the agent should follow. Markdown with headers, lists, code blocks. One focused task per skill.

**Rules** — Always-on context injected into every session. Keep short and directive: "Always...", "Never...", "Prefer...". Plain markdown, no frontmatter.

**Docs** — Searchable knowledge (architecture, schemas, runbooks). Title and description are separate fields; content is just the body in markdown. Found via \`search_docs\` MCP tool.

## When to use what

- Need company knowledge? → \`search_docs\` MCP tool
- Need to see what's available? → \`oc doc list\`, \`oc skill list\`
- Need to create/edit content? → Write content to a temp file, then \`oc <type> create "Name" --file /tmp/content.md\`
- User asks about their setup? → \`oc whoami\`, \`oc teams list\`
- Need a content example? → \`oc skill template\`, \`oc rule template\`, \`oc doc template\`
`)

  // Write MCP config
  const mcpServers = {
    'org-context': {
      type: 'http',
      url: API_URL.replace('/api', '/mcp'),
      headers: { 'x-api-key': API_KEY },
    },
    ...(data.mcpServers || {}),
  }
  writeFileSync(join(PLUGIN_ROOT, '.mcp.json'), JSON.stringify({ mcpServers }, null, 2))

  if (JSON_OUTPUT) return out(data)
  console.log(`${green('✓')} Synced for ${bold(data.email)}`)
  console.log(`  Teams:  ${data.teams.length ? data.teams.join(', ') : dim('none')}`)
  console.log(`  Skills: ${data.skills.length} (written to ${dim(skillsDir)})`)
  console.log(`  Rules:  ${data.rules.length} (written to ${dim(rulesDir)})`)
  console.log(`  MCPs:   ${Object.keys(data.mcpServers || {}).length}`)
  console.log(dim('\nRun /reload-plugins to pick up changes in autocomplete.'))
}

// --- CRUD helpers ---

const HELP = {}

function registerCrud(domain, { plural, nameField, hasDescription }) {
  const p = plural || domain

  commands[`${domain} list`] = async () => {
    const items = await api('GET', `/${p}`)
    if (JSON_OUTPUT) return out(items)
    if (items.length === 0) return console.log(dim(`No ${p}.`))
    const maxName = Math.max(...items.map(i => (i[nameField] || '').length), nameField.length)
    console.log(`${bold('id'.padEnd(8))}  ${bold(nameField.padEnd(maxName))}  ${bold('tags'.padEnd(20))}  ${bold('updated')}`)
    for (const i of items) {
      const id = (i.id || '').slice(0, 8)
      const name = (i[nameField] || '—').padEnd(maxName)
      const tags = ((i.tags || []).join(', ') || '—').padEnd(20)
      console.log(`${dim(id)}  ${name}  ${dim(tags)}  ${dim(timeAgo(i.updatedAt))}`)
    }
    console.log(dim(`\n${items.length} ${p}`))
  }

  async function resolveId(identifier) {
    if (identifier.match(/^[0-9a-f]{8}-/)) return identifier
    const items = await api('GET', `/${p}`)
    // Try ID prefix match first (supports truncated IDs from list output)
    if (identifier.match(/^[0-9a-f]{6,}$/)) {
      const prefixMatches = items.filter(i => i.id.startsWith(identifier))
      if (prefixMatches.length === 1) return prefixMatches[0].id
      if (prefixMatches.length > 1) {
        const list = prefixMatches.map(m => `  ${m.id}  ${m[nameField]}`).join('\n')
        die(`Multiple ${p} match prefix "${identifier}". Use a longer ID:\n${list}`)
      }
    }
    // Fall back to name match
    const matches = items.filter(i => i[nameField]?.toLowerCase() === identifier.toLowerCase())
    if (matches.length === 0) die(`No ${domain} found matching "${identifier}"`)
    if (matches.length > 1) {
      const list = matches.map(m => `  ${m.id}  ${m[nameField]}`).join('\n')
      die(`Multiple ${p} match "${identifier}". Use the ID:\n${list}`)
    }
    return matches[0].id
  }

  commands[`${domain} get`] = async (args) => {
    const { positional } = parseFlags(args)
    if (!positional[0]) die(`Usage: oc ${domain} get <name or id>`)
    const id = await resolveId(positional.join(' '))
    const item = await api('GET', `/${p}/${id}`)
    if (JSON_OUTPUT) return out(item)
    console.log(bold(item[nameField]))
    if (hasDescription && item.description) console.log(dim(item.description))
    console.log(`${dim('ID:')} ${item.id}`)
    console.log(`${dim('Tags:')} ${(item.tags || []).join(', ') || '—'}`)
    console.log(`${dim('Teams:')} ${(item.teams || []).map(t => t.name).join(', ') || '—'}`)
    console.log(`${dim('Org-wide:')} ${item.orgWide ? 'yes' : 'no'}`)
    console.log(`${dim('Updated:')} ${timeAgo(item.updatedAt)}`)
    console.log('')
    console.log(item.content)
  }

  commands[`${domain} create`] = async (args) => {
    const { positional, flags } = parseFlags(args)
    const name = positional[0]
    if (!name) die(`Usage: oc ${domain} create <${nameField}> --file <path> [--tags a,b] [--teams team1,team2] [--org-wide]`)
    const content = readContent(flags)
    if (!content) die('Content required. Use --file <path> or --content "..."')
    const body = {
      [nameField]: name,
      content,
      tags: parseTags(flags) || [],
      teamIds: (await parseTeamIds(flags)) || [],
      orgWide: 'org-wide' in flags,
    }
    if (hasDescription && flags.description) body.description = flags.description
    const item = await api('POST', `/${p}`, body)
    if (JSON_OUTPUT) return out(item)
    console.log(`${green('✓')} Created ${domain}: ${bold(item[nameField])} ${dim(item.id)}`)
  }

  commands[`${domain} update`] = async (args) => {
    const { positional, flags } = parseFlags(args)
    if (!positional[0]) die(`Usage: oc ${domain} update <name or id> [--${nameField} "new name"] [--file <path>] [--tags a,b]`)
    const id = await resolveId(positional.join(' '))
    const body = {}
    if (flags[nameField]) body[nameField] = flags[nameField]
    const content = readContent(flags)
    if (content) body.content = content
    if (flags.tags) body.tags = parseTags(flags)
    if (flags.teams) body.teamIds = await parseTeamIds(flags)
    if ('org-wide' in flags) body.orgWide = true
    if ('no-org-wide' in flags) body.orgWide = false
    if (hasDescription && flags.description) body.description = flags.description
    const item = await api('PUT', `/${p}/${id}`, body)
    if (JSON_OUTPUT) return out(item)
    console.log(`${green('✓')} Updated ${domain}: ${bold(item[nameField])} ${dim(item.id)}`)
  }

  commands[`${domain} delete`] = async (args) => {
    const { positional } = parseFlags(args)
    if (!positional[0]) die(`Usage: oc ${domain} delete <name or id>`)
    const id = await resolveId(positional.join(' '))
    await api('DELETE', `/${p}/${id}`)
    if (JSON_OUTPUT) return out({ success: true })
    console.log(`${green('✓')} Deleted ${domain} ${dim(id)}`)
  }

  commands[`${domain} search`] = async (args) => {
    const { positional, flags } = parseFlags(args)
    const query = positional.join(' ')
    const tag = flags.tag
    if (!query && !tag) die(`Usage: oc ${domain} search <query> [--tag <tag>]`)
    const params = new URLSearchParams()
    if (query) params.set('q', query)
    if (tag) params.set('tag', tag)
    const items = await api('GET', `/${p}/search?${params}`)
    if (JSON_OUTPUT) return out(items)
    if (items.length === 0) return console.log(dim('No results.'))
    for (const i of items) {
      console.log(`${bold(i[nameField])} ${dim(i.id)}`)
      if (i.description) console.log(`  ${dim(i.description)}`)
      if (i.tags?.length) console.log(`  ${dim(i.tags.join(', '))}`)
    }
    console.log(dim(`\n${items.length} results`))
  }

  HELP[`${domain} list`] = `List all ${p}\n  Usage: oc ${domain} list [--json]`
  HELP[`${domain} get`] = `Show a ${domain} by name or ID\n  Usage: oc ${domain} get <name or id> [--json]`
  HELP[`${domain} create`] = `Create a new ${domain}\n  Usage: oc ${domain} create <${nameField}> --file <path> [--tags a,b] [--teams t1,t2] [--org-wide]${hasDescription ? ' [--description "..."]' : ''}`
  HELP[`${domain} update`] = `Update an existing ${domain}\n  Usage: oc ${domain} update <name or id> [--file <path>] [--${nameField} "new"] [--tags a,b] [--teams t1,t2] [--org-wide] [--no-org-wide]`
  HELP[`${domain} delete`] = `Delete a ${domain}\n  Usage: oc ${domain} delete <name or id>`
  HELP[`${domain} search`] = `Search ${p} by text or tag\n  Usage: oc ${domain} search <query> [--tag <tag>]\n\n  Examples:\n    oc ${domain} search hono\n    oc ${domain} search --tag bonnard-stack`
  HELP[`${domain} template`] = `Show example ${domain} content\n  Usage: oc ${domain} template`
}

registerCrud('skill', { plural: 'skills', nameField: 'name', hasDescription: true })
registerCrud('rule', { plural: 'rules', nameField: 'name' })
registerCrud('doc', { plural: 'docs', nameField: 'title', hasDescription: true })

// --- Templates ---

commands['skill template'] = async () => {
  console.log(`# Deploy Checklist

A step-by-step procedure the agent follows when the user invokes this skill.

## Steps

1. Check all tests pass
2. Review uncommitted changes
3. Verify environment variables
4. Run the deploy script

## Notes

- Skills are on-demand — loaded only when the user invokes the slash command
- Write as instructions the AI agent should follow
- Use markdown headers, lists, and code blocks
- Keep focused on one task or workflow`)
}

commands['rule template'] = async () => {
  console.log(`Always write tests for new functions. Use the project's existing test framework.
Prefer integration tests over unit tests for database operations.
Never mock external services in integration tests.

---

Rules are always-on context injected into every AI session.
Keep them short and direct — the agent reads them on every prompt.
Write as instructions: "Always...", "Never...", "Prefer..."
No frontmatter needed — just plain markdown.`)
}

commands['doc template'] = async () => {
  console.log(`# Architecture Overview

High-level description of what this document covers.

## Services

- **backend** — Core platform API (Node.js, PostgreSQL)
- **worker** — Background job processor (Redis queues)
- **frontend** — React SPA served via CDN

## Database

PostgreSQL 15 with read replicas. Schema managed via Drizzle ORM.

## Key Decisions

- Event-driven architecture for cross-service communication
- All secrets in Vault, never in env files

---

Docs are searchable knowledge — architecture, schemas, runbooks, processes.
The agent finds them via the search_docs MCP tool.
Write for an engineer who needs context, not step-by-step instructions (that's a skill).
Title and description are separate fields — the content is just the body.`)
}

// --- Teams ---

async function resolveTeamId(identifier) {
  if (identifier.match(/^[0-9a-f]{8}-/)) return identifier
  const teams = await api('GET', '/teams')
  if (identifier.match(/^[0-9a-f]{6,}$/)) {
    const prefixMatches = teams.filter(t => t.id.startsWith(identifier))
    if (prefixMatches.length === 1) return prefixMatches[0].id
  }
  const matches = teams.filter(t => t.name?.toLowerCase() === identifier.toLowerCase())
  if (matches.length === 0) die(`No team found matching "${identifier}"`)
  if (matches.length > 1) {
    const list = matches.map(t => `  ${t.id}  ${t.name}`).join('\n')
    die(`Multiple teams match "${identifier}". Use the ID:\n${list}`)
  }
  return matches[0].id
}

async function resolveUserIdByEmail(email) {
  const members = await api('GET', '/members')
  const match = members.find(m => m.email?.toLowerCase() === email.toLowerCase())
  if (!match) die(`No member found with email "${email}"`)
  return match.userId
}

async function resolveMemberIdByEmail(email) {
  const members = await api('GET', '/members')
  const match = members.find(m => m.email?.toLowerCase() === email.toLowerCase())
  if (!match) die(`No member found with email "${email}"`)
  return match.id
}

commands['teams list'] = async () => {
  const items = await api('GET', '/teams')
  if (JSON_OUTPUT) return out(items)
  if (items.length === 0) return console.log(dim('No teams.'))
  console.log(`${bold('id'.padEnd(8))}  ${bold('name'.padEnd(25))}  ${bold('members')}  ${bold('skills')}  ${bold('rules')}  ${bold('docs')}`)
  for (const t of items) {
    const id = (t.id || '').slice(0, 8)
    console.log(
      `${dim(id)}  ${t.name.padEnd(25)}  ${String(t.memberCount || 0).padEnd(7)}  ${String(t.skillCount || 0).padEnd(6)}  ${String(t.ruleCount || 0).padEnd(5)}  ${t.docCount || 0}`
    )
  }
  console.log(dim(`\n${items.length} teams`))
}

commands['teams get'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0]) die('Usage: oc teams get <name or id>')
  const id = await resolveTeamId(positional.join(' '))
  const team = await api('GET', `/teams/${id}`)
  if (JSON_OUTPUT) return out(team)
  console.log(bold(team.name))
  console.log(`${dim('ID:')} ${team.id}`)
  if (team.members?.length) {
    console.log(`\n${bold('Members:')}`)
    for (const m of team.members) console.log(`  ${m.user?.email || m.userId}`)
  }
}

commands['teams create'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0]) die('Usage: oc teams create <name>')
  const team = await api('POST', '/teams', { name: positional.join(' ') })
  if (JSON_OUTPUT) return out(team)
  console.log(`${green('✓')} Created team: ${bold(team.name)} ${dim(team.id)}`)
}

commands['teams delete'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0]) die('Usage: oc teams delete <name or id>')
  const id = await resolveTeamId(positional.join(' '))
  await api('DELETE', `/teams/${id}`)
  if (JSON_OUTPUT) return out({ success: true })
  console.log(`${green('✓')} Deleted team ${dim(id)}`)
}

commands['teams add-member'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0] || !positional[1]) die('Usage: oc teams add-member <team-name> <email>')
  const teamId = await resolveTeamId(positional[0])
  const userId = await resolveUserIdByEmail(positional[1])
  await api('POST', `/teams/${teamId}/members`, { userId })
  if (JSON_OUTPUT) return out({ success: true })
  console.log(`${green('✓')} Added ${bold(positional[1])} to team ${bold(positional[0])}`)
}

commands['teams rm-member'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0] || !positional[1]) die('Usage: oc teams rm-member <team-name> <email>')
  const teamId = await resolveTeamId(positional[0])
  const userId = await resolveUserIdByEmail(positional[1])
  await api('DELETE', `/teams/${teamId}/members/${userId}`)
  if (JSON_OUTPUT) return out({ success: true })
  console.log(`${green('✓')} Removed ${bold(positional[1])} from team ${bold(positional[0])}`)
}

// --- Members ---

commands['members list'] = async () => {
  const items = await api('GET', '/members')
  if (JSON_OUTPUT) return out(items)
  if (items.length === 0) return console.log(dim('No members.'))
  const maxEmail = Math.max(...items.map(i => (i.email || '').length), 5)
  console.log(`${bold('email'.padEnd(maxEmail))}  ${bold('name'.padEnd(20))}  ${bold('role'.padEnd(10))}  ${bold('teams')}`)
  for (const m of items) {
    const teams = (m.teams || []).map(t => t.name).join(', ') || '—'
    console.log(`${(m.email || '—').padEnd(maxEmail)}  ${(m.name || '—').padEnd(20)}  ${(m.role || '—').padEnd(10)}  ${dim(teams)}`)
  }
  console.log(dim(`\n${items.length} members`))
}

commands['members invite'] = async (args) => {
  const { positional, flags } = parseFlags(args)
  if (!positional[0]) die('Usage: oc members invite <email> [--role member|admin] [--team <team-name>]')
  const body = { email: positional[0], role: flags.role || 'member' }
  if (flags.team) {
    body.teamId = await resolveTeamId(flags.team)
  }
  await api('POST', '/members/invite', body)
  if (JSON_OUTPUT) return out({ success: true })
  console.log(`${green('✓')} Invited ${bold(positional[0])}`)
}

commands['members set-role'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0] || !positional[1]) die('Usage: oc members set-role <email> <role>')
  const memberId = await resolveMemberIdByEmail(positional[0])
  await api('PUT', `/members/${memberId}/role`, { role: positional[1] })
  if (JSON_OUTPUT) return out({ success: true })
  console.log(`${green('✓')} Set role to ${bold(positional[1])} for ${bold(positional[0])}`)
}

commands['members remove'] = async (args) => {
  const { positional } = parseFlags(args)
  if (!positional[0]) die('Usage: oc members remove <email>')
  const memberId = await resolveMemberIdByEmail(positional[0])
  await api('DELETE', `/members/${memberId}`)
  if (JSON_OUTPUT) return out({ success: true })
  console.log(`${green('✓')} Removed ${bold(positional[0])}`)
}

// --- Help ---

HELP['teams list'] = 'List all teams with member/content counts\n  Usage: oc teams list [--json]'
HELP['teams get'] = 'Show team details and members\n  Usage: oc teams get <name or id> [--json]'
HELP['teams create'] = 'Create a new team\n  Usage: oc teams create <name>'
HELP['teams delete'] = 'Delete a team\n  Usage: oc teams delete <name or id>'
HELP['teams add-member'] = 'Add a member to a team\n  Usage: oc teams add-member <team-name> <email>'
HELP['teams rm-member'] = 'Remove a member from a team\n  Usage: oc teams rm-member <team-name> <email>'
HELP['members list'] = 'List all org members with teams and roles\n  Usage: oc members list [--json]'
HELP['members invite'] = 'Invite a new member to the org\n  Usage: oc members invite <email> [--role member|admin] [--team <team-name>]'
HELP['members set-role'] = 'Change a member\'s role\n  Usage: oc members set-role <email> <role>'
HELP['members remove'] = 'Remove a member from the org\n  Usage: oc members remove <email>'
HELP['whoami'] = 'Show current user identity and organization\n  Usage: oc whoami [--json]'
HELP['sync'] = 'Re-sync skills, rules, and docs from the server\n  Usage: oc sync [--json]'

commands.help = async () => {
  console.log(`${bold('oc')} — Org Context CLI\n`)
  console.log('Usage: oc <command> [args] [--json]\n')
  console.log(bold('General:'))
  console.log('  whoami                          Show current user')
  console.log('  sync                            Re-sync content from server')
  console.log('')
  console.log(bold('Content:'))
  console.log('  skill  list|get|create|update|delete|search|template')
  console.log('  rule   list|get|create|update|delete|search|template')
  console.log('  doc    list|get|create|update|delete|search|template')
  console.log('')
  console.log(bold('Organization:'))
  console.log('  teams   list|get|create|delete|add-member|rm-member')
  console.log('  members list|invite|set-role|remove')
  console.log('')
  console.log(dim('Use --json for machine-readable output.'))
  console.log(dim('Use --file <path> to provide content for create/update.'))
}

// --- Dispatch ---

async function main() {
  const args = process.argv.slice(2).filter(a => a !== '--json')
  const hasHelp = process.argv.includes('--help') || process.argv.includes('-h')
  if (args.length === 0) return commands.help()

  const domain = args.filter(a => a !== '--help' && a !== '-h')[0]
  const action = args.filter(a => a !== '--help' && a !== '-h')[1]
  const rest = args.slice(2).filter(a => a !== '--help' && a !== '-h')

  // --help for a specific command
  if (hasHelp) {
    const key = action ? `${domain} ${action}` : domain
    if (HELP[key]) return console.log(`\n${bold('oc ' + key)}\n\n${HELP[key]}\n`)
    if (Object.keys(HELP).some(k => k.startsWith(domain + ' '))) {
      console.log(`\n${bold('oc ' + domain)}\n`)
      Object.keys(HELP).filter(k => k.startsWith(domain + ' ')).forEach(k => {
        console.log(`  ${bold(k.split(' ')[1].padEnd(12))} ${HELP[k].split('\n')[0]}`)
      })
      console.log('')
      return
    }
    return commands.help()
  }

  // Single-word commands
  if (commands[domain] && typeof commands[domain] === 'function' && !action) {
    return commands[domain](rest)
  }

  // Two-word commands (domain + action)
  const key = `${domain} ${action}`
  if (commands[key]) {
    return commands[key](rest)
  }

  // Domain exists but no action
  if (Object.keys(commands).some(k => k.startsWith(domain + ' '))) {
    const actions = Object.keys(commands)
      .filter(k => k.startsWith(domain + ' '))
      .map(k => k.split(' ')[1])
    console.log(`Usage: oc ${domain} <${actions.join('|')}>`)
    return
  }

  die(`Unknown command: ${args.join(' ')}. Run 'oc help' for usage.`)
}

main().catch(err => {
  if (err.name === 'AbortError') die('Request timed out')
  die(err.message)
})
